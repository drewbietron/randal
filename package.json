{
	"name": "randal",
	"version": "0.1.0",
	"private": true,
	"workspaces": ["packages/*", "tools/*"],
	"bin": {
		"randal": "packages/cli/src/index.ts"
	},
	"scripts": {
		"prepare": "lefthook install || true",
		"test": "bun test",
		"test:unit": "bun test packages/",
		"test:integration": "bun test tests/integration/",
		"test:e2e": "bun test tests/e2e/",
		"test:coverage": "bun test --coverage",
		"test:voice": "bun test packages/voice/",
		"test:voice:integration": "RANDAL_RUN_PROVIDER_TESTS=1 bun test packages/voice/src/providers.integration.test.ts",
		"test:mesh": "bun test packages/mesh/",
		"test:analytics": "bun test packages/analytics/",
		"test:channels": "bun test packages/gateway/src/channels/",
		"test:dashboard": "bun test --preload ./packages/dashboard/src/__tests__/setup.ts packages/dashboard/src/",
		"typecheck": "bunx tsc --noEmit",
		"lint": "bunx biome check .",
		"check": "bun run typecheck && bun run lint && bun run test"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/bun": "^1.2.0",
		"happy-dom": "^20.8.9",
		"typescript": "^5.7.0"
	},
	"dependencies": {
		"chokidar": "^4.0.0",
		"discord.js": "^14.16.0",
		"gray-matter": "^4.0.3",
		"hono": "^4.7.0",
		"meilisearch": "^0.48.0",
		"yaml": "^2.7.0",
		"zod": "^3.24.0"
	}
}
