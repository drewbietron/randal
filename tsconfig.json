{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "./dist",
		"rootDir": ".",
		"composite": true,
		"paths": {
			"@randal/core": ["./packages/core/src/index.ts"],
			"@randal/runner": ["./packages/runner/src/index.ts"],
			"@randal/gateway": ["./packages/gateway/src/index.ts"],
			"@randal/scheduler": ["./packages/scheduler/src/index.ts"],
			"@randal/memory": ["./packages/memory/src/index.ts"],
			"@randal/credentials": ["./packages/credentials/src/index.ts"],
			"@randal/dashboard": ["./packages/dashboard/src/app.ts"],
			"@randal/harness": ["./packages/harness/src/index.ts"]
		}
	},
	"references": [
		{ "path": "./packages/core" },
		{ "path": "./packages/credentials" },
		{ "path": "./packages/runner" },
		{ "path": "./packages/scheduler" },
		{ "path": "./packages/gateway" },
		{ "path": "./packages/memory" },
		{ "path": "./packages/harness" },
		{ "path": "./packages/cli" }
	],
	"include": [],
	"exclude": ["node_modules", "dist"]
}
