# =============================================================================
# Randal Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# OpenCode's opencode.json references these via {env:VAR_NAME} substitution.
# =============================================================================

# --- Core Platform ---
# Anthropic API key (for Claude models)
ANTHROPIC_API_KEY=sk-ant-...
# Gateway auth token (any random string)
RANDAL_API_TOKEN=your-api-token-here
# Hook token for webhook authentication (any random string)
RANDAL_HOOK_TOKEN=your-hook-token-here

# --- GitHub (PR creation, git push, CI status) ---
# GitHub Personal Access Token — enables gh pr create, git push, and CI checks
# Create at: https://github.com/settings/tokens (needs 'repo' scope)
GH_TOKEN=

# --- AI Model Providers ---
# OpenRouter API key (for Gemini, other models via OpenRouter)
OPENROUTER_API_KEY=sk-or-...
# Google AI Studio key (for Veo video generation)
GOOGLE_AI_STUDIO_KEY=your-google-ai-studio-key-here
# Google Vertex API key (for video generation via Vertex AI)
GOOGLE_VERTEX_API_KEY=your-google-vertex-api-key-here
# Google Cloud project ID (for Vertex AI)
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id

# --- Audio (ElevenLabs) ---
# ElevenLabs API key (for text-to-speech in video production)
# Get one at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_...

# --- Video Generation (fal.ai) ---
# fal.ai API key (for video generation via Veo 3, Kling, etc.)
# Sign up at: https://fal.ai — key found at: https://fal.ai/dashboard/keys
FAL_KEY=your-fal-api-key-here

# --- Search & Research ---
# Tavily API key (for web search/research MCP)
TAVILY_API_KEY=tvly-...

# --- Memory (Meilisearch) ---
# Meilisearch master key (auto-generated by agent/setup.sh)
MEILI_MASTER_KEY=your-meilisearch-master-key

# --- Embedding (optional — enables semantic/hybrid search) ---
# Without these, memory and chat search use keyword matching only.
# Requires OPENROUTER_API_KEY to be set above.
# EMBEDDING_MODEL=openai/text-embedding-3-small
# EMBEDDING_URL=https://openrouter.ai/api/v1/embeddings

# --- Integrations ---
# Supabase (for PBV deployment)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_AGENT_KEY=your-supabase-key
# Discord bot token (create at https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=
# BlueBubbles iMessage bridge (macOS only — see docs/deployment-guide.md)
BLUEBUBBLES_URL=http://localhost:1234
BLUEBUBBLES_PASSWORD=
# Apple ID for iMessage (ensure Messages.app is signed in with this account)
APPLE_ID=
