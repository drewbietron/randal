# Randal Environment Variables

# API token for gateway authentication
RANDAL_API_TOKEN=your-api-token-here

# Anthropic API key (for Claude Code / claude-sonnet models)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter API key (for OpenCode with OpenRouter models)
OPENROUTER_API_KEY=sk-or-...

# Meilisearch
MEILI_MASTER_KEY=your-meilisearch-master-key

# Supabase (for PBV deployment)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_AGENT_KEY=your-supabase-key

# Discord (for channel integration, phase 2)
DISCORD_BOT_TOKEN=your-discord-bot-token

# BlueBubbles / iMessage (for channel integration, phase 2)
BLUEBUBBLES_URL=http://localhost:1234
BLUEBUBBLES_PASSWORD=your-bluebubbles-password
