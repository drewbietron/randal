# Railway Environment Variables
# Set these in Railway Dashboard → Variables
# DO NOT commit this file with real values!

# =============================================================================
# AI Model Providers (CHOOSE ONE)
# =============================================================================

# Option A: OpenRouter (Recommended - access to multiple models)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Option B: Direct Anthropic (Claude models only)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# Option C: Direct OpenAI (GPT models only)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# API token for Randal gateway authentication
# Generate with: openssl rand -hex 32
RANDAL_API_TOKEN=your-secure-random-token-here

# Master key for Meilisearch embedded database
# Generate with: openssl rand -hex 32
MEILI_MASTER_KEY=your-secure-meili-key-here

# =============================================================================
# OPTIONAL VARIABLES (for extended functionality)
# =============================================================================

# Tavily API Key for web search capabilities
# Get from: https://tavily.com
TAVILY_API_KEY=tvly-...

# GitHub Personal Access Token for GitHub CLI operations
# Get from: https://github.com/settings/tokens
GH_TOKEN=ghp_...

# Discord Bot Token for Discord integration
# Get from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=...

# FAL API Key for video/image generation
# Get from: https://fal.ai/dashboard
FAL_KEY=...

# ElevenLabs API Key for text-to-speech
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=...
